\documentclass[11pt]{article}
\input{preamble}
\begin{document}

\centerline{\Huge {{ .Identity.Name }}}
\vspace{5pt}
\centerline{
    \href{mailto:{{ .Identity.Email }}}{ {{ .Identity.Email }} } |
    \href{https://www.{{ .Identity.LinkedIn }}}{ {{ .Identity.LinkedIn }} } |
    \href{https://{{ .Identity.Github }}}{ {{ .Identity.Github } }}
}

\vspace{-18pt}

{{ range .Sections }}
    \section*{ {{ .Title }} }
    {{ range .Entries }}
        {{ . }}
        \vspace{-5pt}
    {{ end }}
    {{ .AfterSectionSpacing }}
{{ end }}

\end{document}